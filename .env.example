# Environment
ENVIRONMENT=prod

# Netra API Configuration
NETRA_API_KEY=your_netra_api_key_here
NETRA_OTLP_ENDPOINT=https://api.demo.getnetra.ai/telemetry

# LLM API Keys (choose one - comment out the other)
OPENAI_API_KEY=your_openai_api_key_here
# LITELLM_API_KEY=your_litellm_api_key_here

# Frontend API URL (for development outside Docker)
NEXT_PUBLIC_API_URL=http://localhost:8000
LANGFUSE_SECRET_KEY =
LANGFUSE_PUBLIC_KEY =
# LANGFUSE_BASE_URL = "https://cloud.langfuse.com" # 🇪🇺 EU region
LANGFUSE_BASE_URL = "https://us.cloud.langfuse.com" # 🇺🇸 US region
